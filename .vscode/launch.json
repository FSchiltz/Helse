{
    "version": "0.2.0",
    "configurations": [
        {
            "name": ".NET Core Launch (web)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/Backend/Api/bin/Debug/net10.0/Api.dll",
            "args": [],
            "cwd": "${workspaceFolder}/Backend/Api",
            "stopAtEntry": false,
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            }
        },
        {
            "name": ".NET Core Attach",
            "type": "coreclr",
            "request": "attach"
        },
        {
            "name": ".NET Core Launch with swagger",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/Backend/Api/bin/Debug/net10.0/Api.dll",
            "args": [],
            "cwd": "${workspaceFolder}/Backend/Api",
            "stopAtEntry": false,
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/Views"
            },
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
                "uriFormat": "%s/swagger/index.html"
            }
        },
        {
            "name": "Flutter",
            "type": "dart",
            "request": "launch",
            "program": "flutter_frontend/lib/main.dart",
            "args": [
                "--web-port=8000"
            ]
        },
        {
            "name": "Flutter Desktop",
            "type": "dart",
            "request": "launch",            
            "program": "flutter_frontend/lib/main.dart",
            "args": [
                "-d",
                "linux",
                "--offline"
            ]
        },
        {
            "name": "Flutter web",
            "type": "dart",
            "request": "launch",
            "cwd": "flutter_frontend",
            "args": [
                "-d",
                "chrome",
                "--web-port=8000"
            ]
        }
    ],
    "compounds": [
        {
            "name": "Launch",
            "configurations": [
                "Flutter",
                ".NET Core Launch (web)"
            ],
            "stopAll": true
        }
    ]
}